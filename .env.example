APP_NAME=TIPTAP
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production: set to your real site URL (required for emails, webhooks, absolute links)
# APP_URL=https://your-domain.co.za
# If the app lives in a subfolder, set ASSET_URL to the public URL prefix:
# ASSET_URL=https://your-domain.co.za

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=taptap
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# South Africa (this repo is TAPTAP_sauth — do not use TZ values here)
TIPTAP_MARKET=za
TIPTAP_CURRENCY_SYMBOL=R
TIPTAP_CURRENCY_CODE=ZAR
TIPTAP_COUNTRY_CODE=27
TIPTAP_PAYMENT_GATEWAY=PayFast
TIPTAP_PHONE_EXAMPLE="082 123 4567"
TIPTAP_PHONE_PREFIX=+27

# Sanctum bearer token for WhatsApp bot → /api/bot/* (generate at /admin/bots)
BOT_TOKEN=

# Admin → /admin/infrastructure/docker (super_admin only)
DOCKER_CONTROL_ENABLED=false
DOCKER_CONTROL_POLL_SECONDS=15
# DOCKER_LARAVEL_SSH_HOST=139.59.151.111
# DOCKER_LARAVEL_SSH_KEY=/root/.ssh/id_ed25519
# DOCKER_LARAVEL_WORK_DIR=/root/TIPTAP
# DOCKER_BOT_SSH_HOST=167.71.44.10
# DOCKER_BOT_SSH_KEY=/root/.ssh/id_ed25519
# DOCKER_BOT_WORK_DIR=/opt/tiptap-sauth-bot/tiptopbot

# Admin live dashboard / live orders poll interval (seconds)
ADMIN_LIVE_POLL_SECONDS=30

# Waiter feedback: comments appear on waiter platform after this many minutes (anonymous).
FEEDBACK_VISIBLE_AFTER_MINUTES=60

# WhatsApp bot bill push (Laravel -> Node POST /notify). Use HTTPS in production.
# Laravel forwards Meta webhooks to the same host at /inbound (derived from this URL).
# Example: https://wbot.tiptapafrica.co.za/notify
WHATSAPP_BOT_NOTIFY_URL=
WHATSAPP_BOT_NOTIFY_SECRET=
WHATSAPP_BOT_NOTIFY_TIMEOUT=60

# If the bill PNG URL must include /public (same as your /public/api/bot), set this so the bot can fetch it.
# Bill links look like: {BASE}/bill-image/{id}/{64-char-hex-signature} (path, not ?signature=, for WAF-friendly fetching).
# WHATSAPP_BILL_IMAGE_BASE_URL=https://tiptapafrica.co.za

# WhatsApp Cloud API (Meta). Copy the same values into tiptopbot/.env.
# APP_SECRET is required for production webhook signature verification.
# NEVER put real values in this file — it is committed to git. Put real values in .env (gitignored).
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_GRAPH_VERSION=v20.0
